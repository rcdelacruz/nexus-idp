# Backstage Production Environment Variables for Coolify
# Copy this file and fill in your actual values in Coolify's Environment Variables UI
# DO NOT commit the filled version to Git

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================

# Full HTTPS URL of your Backstage deployment
# Example: https://portal.stratpoint.io or https://backstage.yourdomain.com
APP_BASE_URL=https://<your-coolify-domain>

# Base domain for session cookies (without subdomain)
# Example: If APP_BASE_URL is https://portal.stratpoint.io, use stratpoint.io
SESSION_DOMAIN=<your-base-domain>

# ==============================================================================
# BACKEND AUTHENTICATION
# ==============================================================================

# Backend secret for session encryption (REQUIRED)
# Generate with: node -p 'require("crypto").randomBytes(32).toString("hex")'
# MUST be 64 characters (32 bytes hex-encoded)
BACKEND_SECRET=<generate-with-command-above>

# Backend server port (default: 7007)
PORT=7007

# Node environment
NODE_ENV=production

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# Option 1: Coolify PostgreSQL (recommended for simplicity)
# Use these variable names if you're using Coolify's built-in PostgreSQL service
POSTGRES_HOST=<coolify-postgres-service-name>
POSTGRES_PORT=5432
POSTGRES_USER=backstage
POSTGRES_PASSWORD=<secure-password>
POSTGRES_DB=backstage

# Option 2: Fly.io PostgreSQL (alternative)
# Use these variable names if you're using Fly.io Postgres
# PGHOST=<fly-postgres-hostname>.internal
# PGPORT=5432
# PGUSER=backstage
# PGPASSWORD=<secure-password>
# PGDATABASE=backstage

# ==============================================================================
# GOOGLE OAUTH AUTHENTICATION (PRIMARY)
# ==============================================================================

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_CLIENT_ID=<client-id>.apps.googleusercontent.com

# Google OAuth Client Secret
AUTH_GOOGLE_CLIENT_SECRET=<client-secret>

# IMPORTANT: Update Google OAuth Callback URL
# In Google Cloud Console, add this to "Authorized redirect URIs":
# https://<your-coolify-domain>/api/auth/google/handler/frame

# ==============================================================================
# GITHUB INTEGRATION
# ==============================================================================

# GitHub Personal Access Token
# Scopes required: repo, read:user, user:email
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=<github-personal-access-token>

# ==============================================================================
# CACHING (OPTIONAL BUT RECOMMENDED)
# ==============================================================================

# Cache storage backend
# Options: 'redis' (recommended for production) or 'memory' (default, not recommended)
CACHE_STORE=redis

# Redis connection URL (required if CACHE_STORE=redis)
# Format: redis://:<password>@<host>:<port>
# Upstash example: redis://:abc123@redis-12345.upstash.io:6379
# Coolify Redis example: redis://:<password>@backstage-redis:6379
REDIS_URL=redis://:<password>@<host>:6379

# ==============================================================================
# GITLAB INTEGRATION (OPTIONAL)
# ==============================================================================

# GitLab.com token
# GITLAB.COM_TOKEN=<token>

# Self-hosted GitLab token
# GITLAB_TOKEN=<token>

# ==============================================================================
# KUBERNETES INTEGRATION (OPTIONAL)
# ==============================================================================

# Kubernetes service account token
# KUBERNETES_SERVICE_ACCOUNT_TOKEN=<token>

# ==============================================================================
# ARGOCD INTEGRATION (OPTIONAL)
# ==============================================================================

# ArgoCD authentication token
# Format: argocd.token=<token>
# ARGOCD_AUTH_TOKEN=argocd.token=<token>

# ==============================================================================
# GITHUB OAUTH (OPTIONAL - NOT CURRENTLY USED)
# ==============================================================================

# GitHub OAuth (alternative to Google, currently disabled in production)
# AUTH_GITHUB_CLIENT_ID=<client-id>
# AUTH_GITHUB_CLIENT_SECRET=<client-secret>

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================

# 1. Generate BACKEND_SECRET:
#    node -p 'require("crypto").randomBytes(32).toString("hex")'
#
# 2. Set up Google OAuth:
#    - Go to: https://console.cloud.google.com/apis/credentials
#    - Create OAuth 2.0 Client ID
#    - Add authorized redirect URI: https://<your-domain>/api/auth/google/handler/frame
#    - Copy Client ID and Client Secret
#
# 3. Create GitHub Personal Access Token:
#    - Go to: https://github.com/settings/tokens
#    - Generate new token with scopes: repo, read:user, user:email
#
# 4. Set up PostgreSQL:
#    - Option A: Create PostgreSQL service in Coolify
#    - Option B: Use external provider (Fly.io, Supabase, etc.)
#
# 5. Optional: Set up Redis:
#    - Option A: Create Redis service in Coolify
#    - Option B: Use Upstash (https://upstash.com)
#    - Option C: Skip Redis (use in-memory cache, not recommended)
#
# 6. Configure DNS:
#    - Add A record: <your-subdomain> → <coolify-server-ip>
#    - Wait for DNS propagation (5-30 minutes)
#
# 7. Add these variables in Coolify:
#    - Application → Settings → Environment Variables
#    - Mark sensitive values as "Secret"
#    - Click Save
#
# 8. Deploy:
#    - Click "Deploy" or "Redeploy"
#    - Monitor build logs
#    - First build takes 15-20 minutes
#
# ==============================================================================
# SECURITY NOTES
# ==============================================================================

# - NEVER commit this file with real values to Git
# - Use Coolify's Secrets UI to store sensitive values
# - Rotate BACKEND_SECRET every 90 days
# - Rotate database passwords every 90 days
# - Use strong passwords (24+ characters)
# - Enable MFA on all service accounts

# ==============================================================================
# VERIFICATION AFTER DEPLOYMENT
# ==============================================================================

# 1. Check application is accessible: https://<your-domain>
# 2. Verify SSL certificate is valid (green lock in browser)
# 3. Test Google OAuth login with @stratpoint.com email
# 4. Check catalog entities load (Users, Groups, Components, Systems)
# 5. Test permissions (admin can delete, regular users cannot)
# 6. Verify templates load from engineering-standards repository
# 7. Test search functionality

# For detailed deployment instructions, see:
# - COOLIFY_DEPLOYMENT_PLAN.md (comprehensive guide)
# - COOLIFY_DEPLOYMENT_CHECKLIST.md (30-step checklist)
