# =============================================================================
# ENVIRONMENT VARIABLES FOR DOCKER COMPOSE DEPLOYMENT IN COOLIFY
# =============================================================================
# Copy these into Coolify UI: Application → Settings → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION URLS
# -----------------------------------------------------------------------------
APP_BASE_URL=https://portal.stratpoint.io
SESSION_DOMAIN=stratpoint.io

# -----------------------------------------------------------------------------
# BACKEND SECRETS
# Generate with: node -p 'require("crypto").randomBytes(32).toString("hex")'
# -----------------------------------------------------------------------------
BACKEND_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING

# -----------------------------------------------------------------------------
# DATABASE CREDENTIALS
# Note: POSTGRES_HOST is handled by Docker Compose (internal service: postgres)
# -----------------------------------------------------------------------------
POSTGRES_USER=backstage
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_24_CHARS
POSTGRES_DB=backstage

# -----------------------------------------------------------------------------
# REDIS CREDENTIALS
# Note: Redis URL is handled by Docker Compose (internal service: redis)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_24_CHARS

# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# Setup at: https://console.cloud.google.com/apis/credentials
# Callback URL: https://portal.stratpoint.io/api/auth/google/handler/frame
# -----------------------------------------------------------------------------
AUTH_GOOGLE_CLIENT_ID=REPLACE_WITH_CLIENT_ID.apps.googleusercontent.com
AUTH_GOOGLE_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET

# -----------------------------------------------------------------------------
# GITHUB INTEGRATION
# Generate at: https://github.com/settings/tokens
# Scopes: repo, read:user, user:email
# -----------------------------------------------------------------------------
GITHUB_TOKEN=REPLACE_WITH_ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# OPTIONAL: GITLAB INTEGRATION
# -----------------------------------------------------------------------------
GITLAB_TOKEN=
GITLAB_COM_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL: KUBERNETES INTEGRATION
# -----------------------------------------------------------------------------
KUBERNETES_SERVICE_ACCOUNT_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL: ARGOCD INTEGRATION
# -----------------------------------------------------------------------------
ARGOCD_AUTH_TOKEN=
